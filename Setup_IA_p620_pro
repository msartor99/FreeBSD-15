#!/bin/bash
# ==============================================================================
# STATION IA & INGÉNIERIE - LENOVO P620 (1x 2TB SSD / 2x RTX A4000)
# Déploiement TUI - PUR X11, ZAPPING, AUTOMOUNT, THÈME NASA & AUTO-CLEANUP
# ==============================================================================
set -e

# Identification de l'utilisateur réel
if [ -n "$SUDO_USER" ]; then
    REAL_USER="$SUDO_USER"
else
    REAL_USER="$(whoami)"
fi

# --- 1. GOUVERNANCE ET RESPONSABILITÉ ---
MSG_RESPONSABILITE="Ce script configure une station de calcul haute performance avec IA.\n\nL'Intelligence Artificielle est un outil d'assistance. L'ingénieur reste l'unique responsable de la validation des notes de calculs, du dimensionnement et de l'interprétation des normes (SIA/Eurocodes).\n\nAcceptez-vous ces conditions d'utilisation ?"

if ! whiptail --title "AVERTISSEMENT DE RESPONSABILITÉ" --yesno "$MSG_RESPONSABILITE" 15 70; then
    clear
    echo "Installation annulée par l'opérateur."
    exit 1
fi

# --- 2. IDENTIFICATION DE L'UTILISATEUR ---
NOM_INGENIEUR=$(whiptail --title "PROFIL UTILISATEUR" --inputbox "Entrez le nom ou l'identifiant de l'ingénieur/utilisateur :" 10 60 3>&1 1>&2 2>&3)

if [ $? -ne 0 ] || [ -z "$NOM_INGENIEUR" ]; then
    clear
    echo "Opération annulée. Nom d'utilisateur requis."
    exit 1
fi

# --- 3. CHOIX DU PROFIL MÉTIER ---
CHOIX_IA=$(whiptail --title "CONFIGURATION DE L'INTELLIGENCE ARTIFICIELLE" --menu "Quel modèle métier souhaitez-vous précharger sur les RTX A4000 ?" 15 75 4 \
"1" "Géotechnique (Analyse de sols - Llama-3.1 8B)" \
"2" "Structure (Béton, Acier - Gemma-2 27B)" \
"3" "Infrastructure IT (Réseau, Ansible - CodeLlama 13B)" \
"4" "Déploiement Complet (Les 3 profils)" 3>&1 1>&2 2>&3)

if [ $? -ne 0 ]; then
    clear
    echo "Opération annulée."
    exit 1
fi

clear
echo "========================================================================="
echo " DÉMARRAGE DE L'INSTALLATION POUR : $NOM_INGENIEUR"
echo " Modèle IA sélectionné : Option $CHOIX_IA"
echo "========================================================================="
sleep 2

echo "--- [1/11] RÉGIONALISATION, CLAVIER & ZAPPING X11 ---"
localectl set-x11-keymap ch pc105 fr terminate:ctrl_alt_bksp || true

if grep -q "^XKBOPTIONS=" /etc/default/keyboard; then
    sudo sed -i 's/^XKBOPTIONS=.*/XKBOPTIONS="terminate:ctrl_alt_bksp"/' /etc/default/keyboard
else
    echo 'XKBOPTIONS="terminate:ctrl_alt_bksp"' | sudo tee -a /etc/default/keyboard > /dev/null
fi

sudo mkdir -p /etc/X11/xorg.conf.d
cat <<EOF | sudo tee /etc/X11/xorg.conf.d/90-zapping.conf > /dev/null
Section "ServerFlags"
    Option "DontZap" "false"
EndSection

Section "InputClass"
    Identifier "keyboard-all"
    MatchIsKeyboard "on"
    Option "XkbOptions" "terminate:ctrl_alt_bksp"
EndSection
EOF

sudo -u "$REAL_USER" mkdir -p "/home/$REAL_USER/.config"
cat <<EOF | sudo -u "$REAL_USER" tee "/home/$REAL_USER/.config/kxkbrc" > /dev/null
[Layout]
DisplayNames=
LayoutList=ch(fr)
Options=terminate:ctrl_alt_bksp
ResetOldOptions=true
Use=true
EOF

echo "--- [2/11] MISE À JOUR SYSTÈME PROFONDE ---"
sudo apt update
sudo apt full-upgrade -y
sudo apt autoremove -y

echo "--- [3/11] INSTALLATION DES OUTILS ET CRÉATION DU THÈME SDDM ---"
sudo apt install -y sddm sddm-theme-breeze sddm-theme-maldives kde-standard \
                    plasma-session-x11 firefox vlc git curl build-essential \
                    libreoffice libreoffice-l10n-fr ark okular udisks2 \
                    ansible nmap python3-pip openssh-server ntfs-3g exfatprogs \
                    plymouth plymouth-themes
pip install pywinrm --break-system-packages

# CLONAGE ET DÉPLOIEMENT DU THÈME "NASA"
echo "Déploiement du thème SDDM NASA depuis GitHub..."
sudo rm -rf /usr/share/sddm/themes/nasa
sudo cp -r /usr/share/sddm/themes/maldives /usr/share/sddm/themes/nasa

GH_RAW="https://raw.githubusercontent.com/msartor99/FreeBSD14/3887f2d7ef170978b827d998410bbfe04676205b"

sudo curl -fsSL "$GH_RAW/Main.qml" -o /usr/share/sddm/themes/nasa/Main.qml
sudo curl -fsSL "$GH_RAW/metadata.desktop" -o /usr/share/sddm/themes/nasa/metadata.desktop
sudo curl -fsSL "$GH_RAW/nasa2560login.jpg" -o /usr/share/sddm/themes/nasa/nasa2560login.jpg
sudo curl -fsSL "$GH_RAW/theme.conf" -o /usr/share/sddm/themes/nasa/theme.conf

sudo chmod 644 /usr/share/sddm/themes/nasa/*

sudo mkdir -p /etc/sddm.conf.d
cat <<EOF | sudo tee /etc/sddm.conf.d/x11_strict.conf > /dev/null
[Theme]
Current=nasa

[General]
InputMethod=
DisplayServer=x11

[X11]
MinimumVT=7
EOF

cat <<EOF | sudo -u "$REAL_USER" tee "/home/$REAL_USER/.config/kded_device_automounterrc" > /dev/null
[General]
AutomountEnabled=true
AutomountUnknownDevices=true
AutomountOnLogin=true
AutomountOnPlugin=true
EOF

sudo mkdir -p /usr/share/wayland-sessions/disabled
sudo mv /usr/share/wayland-sessions/*.desktop /usr/share/wayland-sessions/disabled/ 2>/dev/null || true

sudo mkdir -p /var/lib/AccountsService/users/
cat <<EOF | sudo tee /var/lib/AccountsService/users/$REAL_USER > /dev/null
[User]
Session=plasmax11
XSession=plasmax11
Icon=/home/$REAL_USER/.face
SystemAccount=false
EOF

echo "--- [4/11] CONFIGURATION SSH ROOT ---"
sudo sed -i 's/^#*PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config
sudo systemctl restart ssh

echo "--- [5/11] PILOTES NVIDIA ET FIX NOUVEAU ---"
if [ ! -f /etc/modprobe.d/blacklist-nouveau.conf ]; then
    echo "blacklist nouveau" | sudo tee /etc/modprobe.d/blacklist-nouveau.conf > /dev/null
    echo "options nouveau modeset=0" | sudo tee -a /etc/modprobe.d/blacklist-nouveau.conf > /dev/null
fi

if ! nvidia-smi > /dev/null 2>&1; then
    sudo ubuntu-drivers install
else
    echo "Drivers NVIDIA déjà opérationnels."
fi

echo "--- [6/11] OPTIMISATION ACCÉLÉRATION (DRM & MODULES) ---"
if ! grep -q "nvidia-drm.modeset=1" /etc/default/grub; then
    sudo sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT="/GRUB_CMDLINE_LINUX_DEFAULT="nvidia-drm.modeset=1 /' /etc/default/grub
fi

# AUTO-GUÉRISON : Nettoyage du fichier /etc/modules corrompu par de précédentes exécutions en 'sh'
sudo sed -i '/nvidia/d' /etc/modules || true
sudo sed -i '/-e/d' /etc/modules || true

# FIX : Configuration correcte pour Dracut (Early KMS NVIDIA)
sudo mkdir -p /etc/dracut.conf.d
cat <<EOF | sudo tee /etc/dracut.conf.d/nvidia.conf > /dev/null
add_drivers+=" nvidia nvidia_modeset nvidia_uvm nvidia_drm "
EOF

echo "--- [7/11] DOCKER ET ACCÉLÉRATION GPU ---"
if ! command -v docker > /dev/null 2>&1; then
    sudo apt install -y docker.io
fi
sudo systemctl enable --now docker

if [ ! -f /etc/apt/sources.list.d/nvidia-container-toolkit.list ]; then
    curl -4 --retry 3 -fsSL https://nvidia.github.io/libnvidia-container/gpgkey | sudo gpg --dearmor -o /usr/share/keyrings/nvidia-container-toolkit-keyring.gpg
    curl -4 --retry 3 -s -L https://nvidia.github.io/libnvidia-container/stable/deb/nvidia-container-toolkit.list | \
    sed 's#deb https://#deb [signed-by=/usr/share/keyrings/nvidia-container-toolkit-keyring.gpg] https://#g' | \
    sudo tee /etc/apt/sources.list.d/nvidia-container-toolkit.list
    sudo apt update
    sudo apt install -y nvidia-container-toolkit
    sudo systemctl restart docker
fi

echo "--- [8/11] MOTEUR IA ET TÉLÉCHARGEMENT ---"
if ! command -v ollama > /dev/null 2>&1; then
    curl -4 --retry 3 -fsSL https://ollama.com/install.sh | sh
    sleep 5
else
    echo "Ollama est déjà prêt."
fi

DOSSIER_TRAVAIL="/home/$REAL_USER/Documents/Mandats_$NOM_INGENIEUR"
sudo -u "$REAL_USER" mkdir -p "$DOSSIER_TRAVAIL"

case $CHOIX_IA in
    1) ollama pull llama3.1:8b; sudo -u "$REAL_USER" mkdir -p "$DOSSIER_TRAVAIL/Geotechnique" ;;
    2) ollama pull gemma2:27b; sudo -u "$REAL_USER" mkdir -p "$DOSSIER_TRAVAIL/Structure" ;;
    3) ollama pull codellama:13b; sudo -u "$REAL_USER" mkdir -p "$DOSSIER_TRAVAIL/IT_Reseau" ;;
    4)
        ollama pull llama3.1:8b; ollama pull gemma2:27b; ollama pull codellama:13b
        sudo -u "$REAL_USER" mkdir -p "$DOSSIER_TRAVAIL/Geotechnique" "$DOSSIER_TRAVAIL/Structure" "$DOSSIER_TRAVAIL/IT_Reseau"
        ;;
esac

echo "--- [9/11] INTERFACE PROMPT (OPEN WEBUI) ---"
echo "Téléchargement de l'interface visuelle (Ne coupez pas)..."
sudo docker pull ghcr.io/open-webui/open-webui:main

if [ "$(sudo docker ps -aq -f name=open-webui)" ]; then
    sudo docker stop open-webui > /dev/null
    sudo docker rm open-webui > /dev/null
fi
sudo docker run -d -p 3000:8080 --add-host=host.docker.internal:host-gateway -v open-webui:/app/data --name open-webui --restart always ghcr.io/open-webui/open-webui:main

echo "--- [10/11] ACCÈS À DISTANCE (RDP) & MOT DE PASSE ROOT ---"
if ! command -v xrdp > /dev/null 2>&1; then
    sudo apt install -y xrdp
fi
sudo adduser "$REAL_USER" ssl-cert || true
sudo -u "$REAL_USER" bash -c 'echo "startplasma-x11" > ~/.xsession'
sudo systemctl enable --now xrdp

set +e
if whiptail --title "SÉCURITÉ ROOT" --yesno "Voulez-vous définir un mot de passe pour le compte 'root' ?" 10 60; then
    while true; do
        ROOT_PW=$(whiptail --title "MOT DE PASSE ROOT" --passwordbox "Entrez le mot de passe root :" 10 60 3>&1 1>&2 2>&3)
        ROOT_PW_CONFIRM=$(whiptail --title "CONFIRMATION" --passwordbox "Confirmez le mot de passe :" 10 60 3>&1 1>&2 2>&3)
        if [ "$ROOT_PW" = "$ROOT_PW_CONFIRM" ] && [ -n "$ROOT_PW" ]; then
            echo "root:$ROOT_PW" | sudo chpasswd
            break
        else
            whiptail --title "ERREUR" --msgbox "Erreur de saisie. Réessayez." 8 40
        fi
    done
fi
set -e

echo "--- [11/11] CONFIGURATION DU SPLASH SCREEN (PLYMOUTH) NASA ---"
PLYMOUTH_DIR="/usr/share/plymouth/themes/nasa-splash"
sudo mkdir -p $PLYMOUTH_DIR

# Téléchargement direct du fichier PNG natif
sudo curl -fsSL "$GH_RAW/nasa2560login.png" -o $PLYMOUTH_DIR/nasa2560login.png

# Création du fichier de déclaration du thème Plymouth
cat <<EOF | sudo tee $PLYMOUTH_DIR/nasa-splash.plymouth > /dev/null
[Plymouth Theme]
Name=NASA Splash
Description=NASA Boot Splash Screen Custom
ModuleName=script

[script]
ImageDir=$PLYMOUTH_DIR
ScriptFile=$PLYMOUTH_DIR/nasa-splash.script
EOF

# Création du script de centrage d'image pour Plymouth
cat <<EOF | sudo tee $PLYMOUTH_DIR/nasa-splash.script > /dev/null
Window.SetBackgroundTopColor(0.0, 0.0, 0.0);
Window.SetBackgroundBottomColor(0.0, 0.0, 0.0);

bg_image = Image("nasa2560login.png");
screen_ratio = Window.GetWidth() / Window.GetHeight();
bg_image_ratio = bg_image.GetWidth() / bg_image.GetHeight();

if (screen_ratio > bg_image_ratio) {
    scale_factor = Window.GetWidth() / bg_image.GetWidth();
} else {
    scale_factor = Window.GetHeight() / bg_image.GetHeight();
}

scaled_bg_image = bg_image.Scale(bg_image.GetWidth() * scale_factor, bg_image.GetHeight() * scale_factor);
bg_sprite = Sprite(scaled_bg_image);
bg_sprite.SetX(Window.GetWidth() / 2 - scaled_bg_image.GetWidth() / 2);
bg_sprite.SetY(Window.GetHeight() / 2 - scaled_bg_image.GetHeight() / 2);
bg_sprite.SetZ(-10000);
EOF

# Application du thème comme option par défaut du noyau
sudo update-alternatives --install /usr/share/plymouth/themes/default.plymouth default.plymouth $PLYMOUTH_DIR/nasa-splash.plymouth 100
sudo update-alternatives --set default.plymouth $PLYMOUTH_DIR/nasa-splash.plymouth

# Ajout du paramètre "splash" pour GRUB s'il n'y est pas
if ! grep -q "splash" /etc/default/grub; then
    sudo sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT="/GRUB_CMDLINE_LINUX_DEFAULT="splash /' /etc/default/grub
fi

# Compilation propre de l'image de pré-démarrage sans l'erreur Dracut '-e'
sudo update-grub
sudo update-initramfs -u

# --- DEMANDE DE REDÉMARRAGE FINALE ---
MSG_FIN="DÉPLOIEMENT TERMINÉ\n\n- Nettoyage du bug noyau effectué.\n- Thème SDDM 'NASA' installé.\n- Écran Splash NASA configuré.\n- Configuration 100% X11.\n\nVoulez-vous redémarrer maintenant ?"

if whiptail --title "SUCCÈS" --yesno "$MSG_FIN" 15 70; then
    clear
    echo "Redémarrage..."
    sudo reboot
else
    clear
    echo "Opération terminée. N'oubliez pas de redémarrer manuellement."
fi
