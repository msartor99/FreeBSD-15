#!/bin/bash
# ==============================================================================
# STATION IA & INGÉNIERIE - LENOVO P620 (1x 2TB SSD / 2x RTX A4000)
# Déploiement avec Interface TUI - Upgrade, SSH Root, Zapping X11 & Password
# ==============================================================================
set -e

# Identification de l'utilisateur réel
if [ -n "$SUDO_USER" ]; then
    REAL_USER="$SUDO_USER"
else
    REAL_USER="$(whoami)"
fi

# --- 1. GOUVERNANCE ET RESPONSABILITÉ ---
MSG_RESPONSABILITE="Ce script configure une station de calcul haute performance avec IA.\n\nL'Intelligence Artificielle est un outil d'assistance. L'ingénieur reste l'unique responsable de la validation des notes de calculs, du dimensionnement et de l'interprétation des normes (SIA/Eurocodes).\n\nAcceptez-vous ces conditions d'utilisation ?"

if ! whiptail --title "AVERTISSEMENT DE RESPONSABILITÉ" --yesno "$MSG_RESPONSABILITE" 15 70; then
    clear
    echo "Installation annulée par l'opérateur."
    exit 1
fi

# --- 2. IDENTIFICATION DE L'UTILISATEUR ---
NOM_INGENIEUR=$(whiptail --title "PROFIL UTILISATEUR" --inputbox "Entrez le nom ou l'identifiant de l'ingénieur/utilisateur :" 10 60 3>&1 1>&2 2>&3)

if [ $? -ne 0 ] || [ -z "$NOM_INGENIEUR" ]; then
    clear
    echo "Opération annulée. Nom d'utilisateur requis."
    exit 1
fi

# --- 3. CHOIX DU PROFIL MÉTIER ---
CHOIX_IA=$(whiptail --title "CONFIGURATION DE L'INTELLIGENCE ARTIFICIELLE" --menu "Quel modèle métier souhaitez-vous précharger sur les RTX A4000 ?" 15 75 4 \
"1" "Géotechnique (Analyse de sols - Llama-3.1 8B)" \
"2" "Structure (Béton, Acier - Gemma-2 27B)" \
"3" "Infrastructure IT (Réseau, Ansible - CodeLlama 13B)" \
"4" "Déploiement Complet (Les 3 profils)" 3>&1 1>&2 2>&3)

if [ $? -ne 0 ]; then
    clear
    echo "Opération annulée."
    exit 1
fi

clear
echo "========================================================================="
echo " DÉMARRAGE DE L'INSTALLATION POUR : $NOM_INGENIEUR"
echo " Modèle IA sélectionné : Option $CHOIX_IA"
echo "========================================================================="
sleep 2

echo "--- [1/9] RÉGIONALISATION, CLAVIER & ZAPPING X11 ---"
localectl set-x11-keymap ch pc105 fr terminate:ctrl_alt_bksp || true

echo "--- [2/9] MISE À JOUR SYSTÈME PROFONDE ET OUTILS ---"
sudo apt update
sudo apt full-upgrade -y
sudo apt autoremove -y

# Ajout de openssh-server pour garantir la gestion distante
sudo apt install -y sddm kde-standard firefox vlc git curl build-essential \
                    libreoffice libreoffice-l10n-fr ark okular udisks2 \
                    ansible nmap python3-pip openssh-server
pip install pywinrm --break-system-packages

# Autorisation de la connexion SSH en tant que Root
sudo sed -i 's/^#*PermitRootLogin.*/PermitRootLogin yes/' /etc/ssh/sshd_config
sudo systemctl restart ssh

# FIX : Forcer SDDM à utiliser le thème Breeze pour éviter l'écran blanc
sudo mkdir -p /etc/sddm.conf.d
echo -e "[Theme]\nCurrent=breeze" | sudo tee /etc/sddm.conf.d/theme.conf > /dev/null

echo "--- [3/9] PILOTES NVIDIA ET FIX NOUVEAU ---"
if [ ! -f /etc/modprobe.d/blacklist-nouveau.conf ]; then
    echo "blacklist nouveau" | sudo tee /etc/modprobe.d/blacklist-nouveau.conf > /dev/null
    echo "options nouveau modeset=0" | sudo tee -a /etc/modprobe.d/blacklist-nouveau.conf > /dev/null
fi

if ! nvidia-smi > /dev/null 2>&1; then
    sudo ubuntu-drivers install
else
    echo "Drivers NVIDIA déjà opérationnels."
fi

echo "--- [4/9] OPTIMISATION AFFICHAGE NVIDIA (DRM MODESET) ---"
if ! grep -q "nvidia-drm.modeset=1" /etc/default/grub; then
    sudo sed -i 's/GRUB_CMDLINE_LINUX_DEFAULT="/GRUB_CMDLINE_LINUX_DEFAULT="nvidia-drm.modeset=1 /' /etc/default/grub
    sudo update-grub
    sudo update-initramfs -u
fi

echo "--- [5/9] DOCKER ET ACCÉLÉRATION GPU ---"
if ! command -v docker > /dev/null 2>&1; then
    sudo apt install -y docker.io
fi
sudo systemctl enable --now docker

if [ ! -f /etc/apt/sources.list.d/nvidia-container-toolkit.list ]; then
    curl -4 --retry 3 -fsSL https://nvidia.github.io/libnvidia-container/gpgkey | sudo gpg --dearmor -o /usr/share/keyrings/nvidia-container-toolkit-keyring.gpg
    curl -4 --retry 3 -s -L https://nvidia.github.io/libnvidia-container/stable/deb/nvidia-container-toolkit.list | \
    sed 's#deb https://#deb [signed-by=/usr/share/keyrings/nvidia-container-toolkit-keyring.gpg] https://#g' | \
    sudo tee /etc/apt/sources.list.d/nvidia-container-toolkit.list
    sudo apt update
    sudo apt install -y nvidia-container-toolkit
    sudo systemctl restart docker
fi

echo "--- [6/9] MOTEUR IA ET TÉLÉCHARGEMENT ---"
if ! command -v ollama > /dev/null 2>&1; then
    curl -4 --retry 3 -fsSL https://ollama.com/install.sh | sh
    sleep 5
else
    echo "Ollama est déjà prêt."
fi

DOSSIER_TRAVAIL="/home/$REAL_USER/Documents/Mandats_$NOM_INGENIEUR"
sudo -u "$REAL_USER" mkdir -p "$DOSSIER_TRAVAIL"

case $CHOIX_IA in
    1) ollama pull llama3.1:8b; sudo -u "$REAL_USER" mkdir -p "$DOSSIER_TRAVAIL/Geotechnique" ;;
    2) ollama pull gemma2:27b; sudo -u "$REAL_USER" mkdir -p "$DOSSIER_TRAVAIL/Structure" ;;
    3) ollama pull codellama:13b; sudo -u "$REAL_USER" mkdir -p "$DOSSIER_TRAVAIL/IT_Reseau" ;;
    4)
        ollama pull llama3.1:8b; ollama pull gemma2:27b; ollama pull codellama:13b
        sudo -u "$REAL_USER" mkdir -p "$DOSSIER_TRAVAIL/Geotechnique" "$DOSSIER_TRAVAIL/Structure" "$DOSSIER_TRAVAIL/IT_Reseau"
        ;;
esac

echo "--- [7/9] INTERFACE PROMPT (OPEN WEBUI) ---"
echo "Veuillez patienter pendant le téléchargement de l'interface visuelle (Ne faites pas Ctrl+C)..."
sudo docker pull ghcr.io/open-webui/open-webui:main

if [ "$(sudo docker ps -aq -f name=open-webui)" ]; then
    sudo docker stop open-webui > /dev/null
    sudo docker rm open-webui > /dev/null
fi
sudo docker run -d -p 3000:8080 --add-host=host.docker.internal:host-gateway -v open-webui:/app/data --name open-webui --restart always ghcr.io/open-webui/open-webui:main

echo "--- [8/9] ACCÈS À DISTANCE (MICROSOFT RDP) ---"
if ! command -v xrdp > /dev/null 2>&1; then
    sudo apt install -y xrdp
fi
sudo adduser "$REAL_USER" ssl-cert || true
sudo -u "$REAL_USER" bash -c 'echo "startplasma-x11" > ~/.xsession'
sudo systemctl enable --now xrdp

echo "--- [9/9] SÉCURISATION DU COMPTE ROOT ---"
# Désactivation temporaire de l'arrêt sur erreur pour gérer correctement la boucle Whiptail
set +e
if whiptail --title "SÉCURITÉ ROOT" --yesno "Voulez-vous définir un mot de passe pour le compte 'root' maintenant ?\n\n(Fortement recommandé puisque l'accès SSH Root a été activé)" 12 70; then
    while true; do
        ROOT_PW=$(whiptail --title "MOT DE PASSE ROOT" --passwordbox "Entrez le nouveau mot de passe pour root :" 10 60 3>&1 1>&2 2>&3)
        if [ $? -ne 0 ]; then
            whiptail --title "ANNULATION" --msgbox "Configuration du mot de passe root ignorée." 8 50
            break
        fi
        
        ROOT_PW_CONFIRM=$(whiptail --title "CONFIRMATION" --passwordbox "Confirmez le mot de passe :" 10 60 3>&1 1>&2 2>&3)
        if [ $? -ne 0 ]; then
            whiptail --title "ANNULATION" --msgbox "Configuration du mot de passe root ignorée." 8 50
            break
        fi
        
        if [ "$ROOT_PW" = "$ROOT_PW_CONFIRM" ] && [ -n "$ROOT_PW" ]; then
            echo "root:$ROOT_PW" | sudo chpasswd
            whiptail --title "SUCCÈS" --msgbox "Le mot de passe root a été mis à jour avec succès." 8 50
            break
        else
            whiptail --title "ERREUR" --msgbox "Les mots de passe ne correspondent pas ou sont vides. Veuillez réessayer." 8 60
        fi
    done
fi

# --- DEMANDE DE REDÉMARRAGE FINALE ---
MSG_FIN="DÉPLOIEMENT TERMINÉ AVEC SUCCÈS POUR : $NOM_INGENIEUR\n\n1. Raccourci de secours activé : Ctrl+Alt+Backspace.\n2. Interface IA accessible sur http://localhost:3000\n\nVoulez-vous redémarrer le système maintenant pour appliquer toutes les modifications (NVIDIA, SDDM, etc.) ?"

if whiptail --title "INSTALLATION TERMINÉE - REDÉMARRAGE" --yesno "$MSG_FIN" 14 75; then
    clear
    echo "Redémarrage du système..."
    sudo reboot
else
    clear
    echo "========================================================================="
    echo " Redémarrage ignoré."
    echo " N'oubliez pas de redémarrer manuellement (sudo reboot) plus tard pour"
    echo " activer l'accélération matérielle NVIDIA et l'interface graphique."
    echo "========================================================================="
fi

# Réactivation de l'arrêt sur erreur (bonne pratique pour terminer)
set -e
